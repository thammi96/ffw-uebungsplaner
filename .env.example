# Server Configuration
PORT=3001
SESSION_SECRET=super-secret-session-key-change-me-in-production

# Database Configuration
# In docker-compose, this will map to /app/data/database.sqlite
DB_PATH=./data/database.sqlite

# Microsoft Entra ID Integration
# Set these to enable Entra ID authentication for Admins
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_TENANT_ID=your-tenant-id
ENTRA_REDIRECT_URI=https://uebung.musterstadt.de/auth/callback
ENTRA_ADMIN_GROUP_ID=your-admin-group-id

# Local Debug Auth Bypass
# Set to 'true' to allow logging in as a mock Admin without Microsoft Entra
LOCAL_DEBUG_ADMIN=false
LOCAL_DEBUG_ADMIN_NAME=Debug Admin

# PWA Web Push Configuration
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@ffw-uebungsplaner.local
