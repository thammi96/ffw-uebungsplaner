<%- include('partials/header') %>

<!-- Air Datepicker CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/air-datepicker@3.5.3/air-datepicker.css">
<style>
  /* Air Datepicker - FFW Brand Overrides (Light Mode) */
  .air-datepicker {
    --adp-font-family: 'Outfit', sans-serif;
    --adp-font-size: 13px;
    --adp-width: 280px;
    --adp-z-index: 100;
    --adp-padding: 8px;
    --adp-grid-areas: 'nav' 'body' 'timepicker' 'buttons';
    --adp-color: #0f172a;
    --adp-color-secondary: #64748b;
    --adp-accent-color: #dc2626;
    --adp-color-current-date: #dc2626;
    --adp-nav-arrow-color: #475569;
    --adp-background-color: #ffffff;
    --adp-background-color-hover: #f1f5f9;
    --adp-background-color-active: #dc2626;
    --adp-background-color-in-range: rgba(220, 38, 38, 0.12);
    --adp-background-color-in-range-focused: rgba(220, 38, 38, 0.2);
    --adp-color-disabled: #cbd5e1;
    --adp-color-disabled-in-range: rgba(220, 38, 38, 0.35);
    --adp-color-other-month: #94a3b8;
    --adp-border-color: rgba(15, 23, 42, 0.1);
    --adp-border-color-inner: rgba(15, 23, 42, 0.06);
    --adp-nav-border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    --adp-nav-title-color: #0f172a;
    --adp-day-name-color: #64748b;
    --adp-day-cell-height: 34px;
    --adp-day-cell-width: 34px;
    --adp-month-cell-height: 48px;
    --adp-year-cell-height: 44px;
    --adp-pointer-size: 10px;
    --adp-cell-border-radius: 50%;
    --adp-time-track-color: #cbd5e1;
    --adp-time-track-color-selected: #dc2626;
    --adp-time-thumb-size: 16px;
    --adp-time-padding-inner: 10px;
    --adp-button-color: #dc2626;
    border-radius: 1rem !important;
    border: 1px solid rgba(15, 23, 42, 0.09) !important;
    box-shadow: 0 20px 40px -8px rgba(0,0,0,0.18), 0 8px 16px -4px rgba(0,0,0,0.08) !important;
    font-family: 'Outfit', sans-serif !important;
  }
  /* Air Datepicker - Dark Mode */
  .dark .air-datepicker {
    --adp-color: #f1f5f9;
    --adp-color-secondary: #94a3b8;
    --adp-accent-color: #ef4444;
    --adp-color-current-date: #ef4444;
    --adp-nav-arrow-color: #94a3b8;
    --adp-background-color: #0f172a;
    --adp-background-color-hover: #1e293b;
    --adp-background-color-active: #dc2626;
    --adp-background-color-in-range: rgba(220, 38, 38, 0.2);
    --adp-background-color-in-range-focused: rgba(220, 38, 38, 0.3);
    --adp-color-disabled: #334155;
    --adp-color-other-month: #475569;
    --adp-border-color: rgba(255, 255, 255, 0.08);
    --adp-border-color-inner: rgba(255, 255, 255, 0.05);
    --adp-nav-border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    --adp-nav-title-color: #f1f5f9;
    --adp-day-name-color: #64748b;
    --adp-time-track-color: #334155;
    --adp-time-track-color-selected: #dc2626;
    --adp-button-color: #ef4444;
    border: 1px solid rgba(255,255,255,0.08) !important;
    box-shadow: 0 25px 50px -10px rgba(0,0,0,0.6), 0 10px 20px -5px rgba(0,0,0,0.3) !important;
  }
  /* Nav title hover */
  .air-datepicker-nav--title:hover {
    color: #dc2626 !important;
  }
  /* Timepicker label */
  .air-datepicker-time--current-hours,
  .air-datepicker-time--current-minutes {
    font-family: 'Outfit', sans-serif !important;
    font-weight: 700 !important;
  }
  /* Selected day text white */
  .air-datepicker-cell.-selected- {
    color: #fff !important;
    font-weight: 700 !important;
  }
</style>

<div class="space-y-6">

  <!-- TAB CONTENT 1: Events -->
  <div id="tab-content-events" class="space-y-6">
    <!-- Pending Approvals Alert if any -->
    <% if (pendingUsers.length > 0) { %>
      <div class="p-4 bg-yellow-100 dark:bg-yellow-950/40 border border-yellow-300 dark:border-yellow-800/40 text-yellow-800 dark:text-yellow-300 rounded-2xl flex items-center justify-between shadow-lg">
        <div class="flex items-center space-x-3">
          <div class="h-9 w-9 rounded-xl bg-yellow-200 dark:bg-yellow-900/40 flex items-center justify-center text-yellow-600 dark:text-yellow-400">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Ausstehende Freigaben</h4>
            <p class="text-xs text-yellow-700/90 dark:text-yellow-400/80">Es gibt <%= pendingUsers.length %> neue Mitglieder, die freigegeben werden müssen.</p>
          </div>
        </div>
        <button onclick="switchTab('users')" class="px-3.5 py-1.5 bg-yellow-600 hover:bg-yellow-500 dark:bg-yellow-800 dark:hover:bg-yellow-700 text-white dark:text-yellow-100 font-semibold text-xs rounded-lg transition-colors">
          Freigeben
        </button>
      </div>
    <% } %>

    <!-- Create Event Form -->
    <div id="create-event-container" class="glass-panel rounded-2xl p-6 hidden">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Neue Übung/Termin erstellen</h3>
      <form action="/admin/event/new" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Titel der Übung</label>
          <input type="text" name="title" required placeholder="z. B. Atemschutzübung / Dienstabend" 
                 class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-600 font-medium text-sm transition-colors">
        </div>
        
        <div>
          <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Datum & Uhrzeit</label>
          <input type="text" id="event_date_picker" placeholder="Termin wählen..." readonly
                 class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors cursor-pointer">
          <input type="hidden" id="event_date_hidden" name="event_date" required>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Zielgruppe (Mannschaft)</label>
          <select name="target_group" class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
            <option value="ALLE">Alle (Jugend & Aktive)</option>
            <option value="JUGEND">Jugendfeuerwehr</option>
            <option value="AKTIVE">Aktive Mannschaft</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-xs text-slate-500 dark:text-slate-400 mb-1.5">1. Erinnerung (Minuten vorher)</label>
            <input type="number" name="reminder_1_minutes" value="1440" required
                   class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
          </div>
          <div>
            <label class="block text-xs text-slate-500 dark:text-slate-400 mb-1.5">2. Erinnerung (Minuten vorher)</label>
            <input type="number" name="reminder_2_minutes" value="60" required
                   class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
          </div>
        </div>

        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Beschreibung / Mitzubringen</label>
          <textarea name="description" rows="3" placeholder="Details zur Übung, Treffpunkt, Kleidung..."
                    class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-600 font-medium text-sm transition-colors"></textarea>
        </div>

        <div class="md:col-span-2 text-right">
          <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl text-sm shadow-lg shadow-brand-600/15 transition-all">
            Übung speichern & veröffentlichen
          </button>
        </div>
      </form>
    </div>

    <!-- Active Events List -->
    <div class="space-y-4">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Aktuelle Übungsplanung</h3>
      
      <% if (events.length === 0) { %>
        <div class="glass-panel rounded-2xl p-8 text-center text-slate-500 text-sm">
          Keine Übungen geplant. Nutze das Formular oben, um eine Übung zu erstellen.
        </div>
      <% } else { %>
        <% events.forEach(event => { %>
          <div class="glass-panel rounded-2xl border border-slate-200 dark:border-slate-800/80 overflow-hidden shadow-sm">
            <!-- Event Card Summary Header -->
            <div class="p-5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-slate-100/50 dark:bg-slate-900/30 border-b border-slate-200 dark:border-slate-850">
              <div>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-300 dark:border-slate-700/60 mb-2">
                  <%= event.target_group %>
                </span>
                <h4 class="text-lg font-bold text-slate-900 dark:text-white"><%= event.title %></h4>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5"><%= event.formatted_date %> Uhr</p>
              </div>

              <!-- Signup Statistics pill badge -->
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold bg-green-100 dark:bg-green-950/60 border border-green-200 dark:border-green-800/40 text-green-700 dark:text-green-400">
                  <span class="h-2 w-2 rounded-full bg-green-500 dark:bg-green-400"></span>
                  <%= event.yes_count %> Zusagen
                </span>
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold bg-red-100 dark:bg-red-950/60 border border-red-200 dark:border-red-800/40 text-red-700 dark:text-red-400">
                  <span class="h-2 w-2 rounded-full bg-red-500 dark:bg-red-400"></span>
                  <%= event.no_count %> Absagen
                </span>
              </div>
            </div>

            <!-- Event Details Panel -->
            <div class="p-5 space-y-4">
              <!-- Inline description -->
              <% if (event.description) { %>
                <div class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed max-w-2xl bg-slate-100/50 dark:bg-slate-900/10 p-3 rounded-lg border border-slate-200 dark:border-slate-900">
                  <%= event.description %>
                </div>
              <% } %>

              <!-- Attendee List Table -->
              <div class="overflow-x-auto">
                <table class="w-full text-left text-xs border-collapse">
                  <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-500 uppercase tracking-wider font-semibold">
                      <th class="py-2.5">Mitglied</th>
                      <th class="py-2.5">Handy</th>
                      <th class="py-2.5">Status</th>
                      <th class="py-2.5">Kommentar / Rückmeldung</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% const signups = eventSignups[event.id] || []; %>
                    <% if (signups.length === 0) { %>
                      <tr>
                        <td colspan="4" class="py-4 text-center text-slate-400 dark:text-slate-600">Keine Rückmeldungen vorhanden.</td>
                      </tr>
                    <% } else { %>
                      <% signups.forEach(signup => { %>
                        <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-200/20 dark:hover:bg-slate-900/20">
                          <td class="py-2.5 font-bold text-slate-800 dark:text-slate-200"><%= signup.name %></td>
                          <td class="py-2.5 text-slate-500 dark:text-slate-400 font-mono"><%= signup.phone_number %></td>
                          <td class="py-2.5">
                            <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold <%= signup.status === 'ZUSAGE' ? 'bg-green-100 border border-green-300 text-green-700 dark:bg-green-950/50 dark:border-green-800/40 dark:text-green-400' : 'bg-red-100 border border-red-300 text-red-700 dark:bg-red-950/50 dark:border-red-800/40 dark:text-red-400' %>">
                              <%= signup.status %>
                            </span>
                          </td>
                          <td class="py-2.5 text-slate-700 dark:text-slate-300 italic"><%= signup.comment || '—' %></td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Action Buttons for Event -->
              <div class="flex flex-wrap items-center justify-between border-t border-slate-200 dark:border-slate-800/60 pt-4 gap-2">
                <!-- Push notifications trigger -->
                <form action="/admin/event/<%= event.id %>/send-reminders" method="POST">
                  <button type="submit" 
                          class="px-3 py-1.5 bg-slate-200 hover:bg-slate-300 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 font-semibold text-xs rounded-lg border border-slate-300 dark:border-slate-750 transition-colors flex items-center gap-1.5 shadow-sm">
                    <svg class="h-3.5 w-3.5 text-brand-500 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                    Manuell Push-Erinnerung senden
                  </button>
                </form>

                  <!-- Öffentlicher Link: open, WhatsApp share, copy -->
                  <a href="/event/<%= event.id %>" target="_blank" 
                     class="px-3 py-1.5 border border-slate-300 dark:border-slate-750 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white text-xs font-semibold rounded-lg transition-colors shadow-sm flex items-center gap-1.5">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    Link öffnen
                  </a>

                  <!-- WhatsApp Teilen -->
                  <button onclick="shareWhatsApp('<%= event.id %>', '<%= event.title.replace(/'/g, `\'`) %>', '<%= event.formatted_date %>')"
                          class="px-3 py-1.5 bg-green-500 hover:bg-green-600 text-white text-xs font-bold rounded-lg transition-colors shadow-sm flex items-center gap-1.5">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.526 5.847L.057 23.487a.75.75 0 00.921.921l5.64-1.469A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.713 9.713 0 01-4.953-1.355l-.354-.213-3.676.957.976-3.565-.232-.366A9.713 9.713 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
                    </svg>
                    WhatsApp
                  </button>

                  <!-- Link kopieren -->
                  <button id="copy-btn-<%= event.id %>" onclick="copyEventLink('<%= event.id %>')"
                          class="px-3 py-1.5 border border-slate-300 dark:border-slate-750 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 text-xs font-semibold rounded-lg transition-colors shadow-sm flex items-center gap-1.5">
                    <svg id="copy-icon-<%= event.id %>" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                    <span id="copy-label-<%= event.id %>">Link kopieren</span>
                  </button>
                  
                  <!-- Delete Event Form -->
                  <form action="/admin/event/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Soll diese Übung wirklich gelöscht werden?');">
                    <button type="submit" 
                            class="px-3 py-1.5 bg-red-50 border border-red-200 hover:bg-red-100 text-red-600 dark:bg-red-950/40 dark:border-red-900/60 dark:hover:bg-red-950/70 dark:text-red-400 text-xs font-semibold rounded-lg transition-colors shadow-sm">
                      Übung löschen
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- TAB CONTENT 1.5: Past Events -->
  <div id="tab-content-past-events" class="space-y-6 hidden">
    <!-- Past Events List -->
    <div class="space-y-4">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Vergangene Übungen</h3>
      
      <% if (pastEvents.length === 0) { %>
        <div class="glass-panel rounded-2xl p-8 text-center text-slate-500 text-sm">
          Keine vergangenen Übungen vorhanden.
        </div>
      <% } else { %>
        <% pastEvents.forEach(event => { %>
          <div class="glass-panel rounded-2xl border border-slate-200 dark:border-slate-800/80 overflow-hidden shadow-sm">
            <!-- Event Card Summary Header -->
            <div class="p-5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-slate-100/50 dark:bg-slate-900/30 border-b border-slate-200 dark:border-slate-850">
              <div>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-300 dark:border-slate-700/60 mb-2">
                  <%= event.target_group %>
                </span>
                <h4 class="text-lg font-bold text-slate-900 dark:text-white"><%= event.title %></h4>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5"><%= event.formatted_date %> Uhr</p>
              </div>

              <!-- Signup Statistics pill badge -->
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold bg-green-100 dark:bg-green-950/60 border border-green-200 dark:border-green-800/40 text-green-700 dark:text-green-400">
                  <span class="h-2 w-2 rounded-full bg-green-500 dark:bg-green-400"></span>
                  <%= event.yes_count %> Zusagen
                </span>
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-semibold bg-red-100 dark:bg-red-950/60 border border-red-200 dark:border-red-800/40 text-red-700 dark:text-red-400">
                  <span class="h-2 w-2 rounded-full bg-red-500 dark:bg-green-400"></span>
                  <%= event.no_count %> Absagen
                </span>
              </div>
            </div>

            <!-- Event Details Panel -->
            <div class="p-5 space-y-4">
              <!-- Inline description -->
              <% if (event.description) { %>
                <div class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed max-w-2xl bg-slate-100/50 dark:bg-slate-900/10 p-3 rounded-lg border border-slate-200 dark:border-slate-900">
                  <%= event.description %>
                </div>
              <% } %>

              <!-- Attendee List Table -->
              <div class="overflow-x-auto">
                <table class="w-full text-left text-xs border-collapse">
                  <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-500 uppercase tracking-wider font-semibold">
                      <th class="py-2.5">Mitglied</th>
                      <th class="py-2.5">Handy</th>
                      <th class="py-2.5">Status</th>
                      <th class="py-2.5">Kommentar / Rückmeldung</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% const signups = eventSignups[event.id] || []; %>
                    <% if (signups.length === 0) { %>
                      <tr>
                        <td colspan="4" class="py-4 text-center text-slate-400 dark:text-slate-600">Keine Rückmeldungen vorhanden.</td>
                      </tr>
                    <% } else { %>
                      <% signups.forEach(signup => { %>
                        <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-200/20 dark:hover:bg-slate-900/20">
                          <td class="py-2.5 font-bold text-slate-800 dark:text-slate-200"><%= signup.name %></td>
                          <td class="py-2.5 text-slate-500 dark:text-slate-400 font-mono"><%= signup.phone_number %></td>
                          <td class="py-2.5">
                            <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold <%= signup.status === 'ZUSAGE' ? 'bg-green-100 border border-green-300 text-green-700 dark:bg-green-950/50 dark:border-green-800/40 dark:text-green-400' : 'bg-red-100 border border-red-300 text-red-700 dark:bg-red-950/50 dark:border-red-800/40 dark:text-red-400' %>">
                              <%= signup.status %>
                            </span>
                          </td>
                          <td class="py-2.5 text-slate-700 dark:text-slate-300 italic"><%= signup.comment || '—' %></td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Action Buttons for Event -->
              <div class="flex flex-wrap items-center justify-between border-t border-slate-200 dark:border-slate-800/60 pt-4 gap-2">
                <div class="flex items-center gap-2">
                  <a href="/event/<%= event.id %>" target="_blank" 
                     class="px-3 py-1.5 border border-slate-300 dark:border-slate-750 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white text-xs font-semibold rounded-lg transition-colors shadow-sm flex items-center gap-1.5">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    Link öffnen
                  </a>

                  <!-- WhatsApp Teilen -->
                  <button onclick="shareWhatsApp('<%= event.id %>', '<%= event.title.replace(/'/g, `\'`) %>', '<%= event.formatted_date %>')"
                          class="px-3 py-1.5 bg-green-500 hover:bg-green-600 text-white text-xs font-bold rounded-lg transition-colors shadow-sm flex items-center gap-1.5">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.526 5.847L.057 23.487a.75.75 0 00.921.921l5.64-1.469A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.713 9.713 0 01-4.953-1.355l-.354-.213-3.676.957.976-3.565-.232-.366A9.713 9.713 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
                    </svg>
                    WhatsApp
                  </button>

                  <!-- Link kopieren -->
                  <button id="copy-btn-<%= event.id %>-past" onclick="copyEventLink('<%= event.id %>')"
                          class="px-3 py-1.5 border border-slate-300 dark:border-slate-750 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 text-xs font-semibold rounded-lg transition-colors shadow-sm flex items-center gap-1.5">
                    <svg id="copy-icon-<%= event.id %>" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                    <span id="copy-label-<%= event.id %>">Link kopieren</span>
                  </button>
                  
                  <!-- Delete Event Form -->
                  <form action="/admin/event/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Soll diese Übung wirklich gelöscht werden?');">
                    <button type="submit" 
                            class="px-3 py-1.5 bg-red-50 border border-red-200 hover:bg-red-100 text-red-600 dark:bg-red-950/40 dark:border-red-900/60 dark:hover:bg-red-950/70 dark:text-red-400 text-xs font-semibold rounded-lg transition-colors shadow-sm">
                      Übung löschen
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- TAB CONTENT 2: Users Management -->
  <div id="tab-content-users" class="space-y-6 hidden">
    <!-- Pending Approvals section -->
    <div class="glass-panel rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Ausstehende Freigabe-Anfragen</h3>
      
      <% if (pendingUsers.length === 0) { %>
        <p class="text-slate-500 dark:text-slate-400 text-sm py-2">Keine ausstehenden Registrierungsanfragen.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-xs border-collapse">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-500 uppercase tracking-wider font-semibold">
                <th class="py-2.5">Name</th>
                <th class="py-2.5">Handynummer</th>
                <th class="py-2.5">Abteilung</th>
                <th class="py-2.5">Datum der Anfrage</th>
                <th class="py-2.5 text-right">Aktionen</th>
              </tr>
            </thead>
            <tbody>
              <% pendingUsers.forEach(user => { %>
                <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-200/20 dark:hover:bg-slate-900/20">
                  <td class="py-3 font-bold text-slate-800 dark:text-slate-200"><%= user.name %></td>
                  <td class="py-3 text-slate-500 dark:text-slate-400 font-mono"><%= user.phone_number %></td>
                  <td class="py-3 text-slate-700 dark:text-slate-300"><%= user.group_type === 'JUGEND' ? 'Jugendfeuerwehr' : (user.group_type === 'AKTIVE' ? 'Aktive Mannschaft' : 'Beide / Ausbilder') %></td>
                  <td class="py-3 text-slate-500"><%= new Date(user.created_at).toLocaleDateString('de-DE') %></td>
                  <td class="py-3 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <form action="/admin/user/<%= user.id %>/approve" method="POST">
                        <button type="submit" 
                                class="px-2.5 py-1 bg-green-600 hover:bg-green-500 text-white font-semibold text-xs rounded transition-colors shadow">
                          Freigeben
                        </button>
                      </form>
                      <form action="/admin/user/<%= user.id %>/delete" method="POST" onsubmit="return confirm('Registrierungsanfrage ablehnen und löschen?');">
                        <button type="submit" 
                                class="px-2.5 py-1 bg-red-50 border border-red-200 text-red-600 dark:bg-red-950/40 dark:border-red-900/60 dark:hover:bg-red-950/70 dark:text-red-400 text-xs font-semibold rounded transition-colors">
                          Ablehnen
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Approved Users Directory -->
    <div class="glass-panel rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Mitglieder-Verzeichnis</h3>
      
      <% if (approvedUsers.length === 0) { %>
        <p class="text-slate-500 dark:text-slate-400 text-sm py-2">Noch keine freigegebenen Mitglieder.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-xs border-collapse">
            <thead>
              <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-500 uppercase tracking-wider font-semibold">
                <th class="py-2.5">Name</th>
                <th class="py-2.5">Handynummer</th>
                <th class="py-2.5">Abteilung</th>
                <th class="py-2.5 text-right">Aktionen</th>
              </tr>
            </thead>
            <tbody>
              <% approvedUsers.forEach(user => { %>
                <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-200/20 dark:hover:bg-slate-900/20">
                  <td class="py-3 font-bold text-slate-800 dark:text-slate-200"><%= user.name %></td>
                  <td class="py-3 text-slate-500 dark:text-slate-400 font-mono"><%= user.phone_number %></td>
                  <td class="py-3 text-slate-700 dark:text-slate-300"><%= user.group_type === 'JUGEND' ? 'Jugendfeuerwehr' : (user.group_type === 'AKTIVE' ? 'Aktive Mannschaft' : 'Beide / Ausbilder') %></td>
                  <td class="py-3 text-right">
                    <form action="/admin/user/<%= user.id %>/delete" method="POST" onsubmit="return confirm('Mitglied und alle dessen Rückmeldungen wirklich löschen?');">
                      <button type="submit" 
                              class="px-2.5 py-1 bg-red-50 border border-red-200 text-red-650 dark:bg-red-950/40 dark:border-red-900/60 dark:hover:bg-red-950/70 dark:text-red-400 text-xs font-semibold rounded transition-colors">
                        Löschen
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- TAB CONTENT 3: Audit Logs -->
  <div id="tab-content-audit" class="space-y-4 hidden">
    <div class="glass-panel rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">System-Protokoll (Audit logs)</h3>
      <p class="text-xs text-slate-500 dark:text-slate-400 mb-4 font-medium">Lückenlose Protokollierung aller administrativen Aktivitäten und Registrierungen.</p>
      
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs border-collapse">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-800 text-slate-500 uppercase tracking-wider font-semibold">
              <th class="py-2.5 w-1/5">Zeitstempel</th>
              <th class="py-2.5 w-1/5">Benutzer</th>
              <th class="py-2.5 w-1/5">Aktion</th>
              <th class="py-2.5 w-1/3">Details</th>
              <th class="py-2.5">IP-Adresse</th>
            </tr>
          </thead>
          <tbody>
            <% auditLogs.forEach(log => { %>
              <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-200/20 dark:hover:bg-slate-900/20">
                <td class="py-2.5 text-slate-500 dark:text-slate-400 font-mono"><%= log.formatted_date %></td>
                <td class="py-2.5 text-slate-800 dark:text-slate-200 font-bold"><%= log.user_name || 'System' %></td>
                <td class="py-2.5">
                  <span class="inline-block px-1.5 py-0.5 rounded text-[9px] font-bold font-mono 
                    <%= log.action.includes('SUCCESS') ? 'bg-green-100 text-green-700 dark:bg-green-950/50 dark:text-green-400 border border-green-300 dark:border-green-800/40' : 
                       (log.action.includes('FAILURE') ? 'bg-red-100 text-red-700 dark:bg-red-950/50 dark:text-red-400 border border-red-300 dark:border-red-800/40' : 
                       (log.action.includes('DELETE') ? 'bg-orange-100 text-orange-700 dark:bg-orange-950/50 dark:text-orange-400 border border-orange-300 dark:border-orange-800/40' : 'bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-300')) %>">
                    <%= log.action %>
                  </span>
                </td>
                <td class="py-2.5 text-slate-700 dark:text-slate-300"><%= log.details %></td>
                <td class="py-2.5 text-slate-500 dark:text-slate-500 font-mono text-[11px]"><%= log.ip_address || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- TAB CONTENT 4: Settings -->
  <div id="tab-content-settings" class="space-y-6 hidden">
    <!-- General settings form -->
    <div class="glass-panel rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Allgemeine App-Einstellungen</h3>
      <form action="/admin/settings/save" method="POST" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Name der App (Titel)</label>
            <input type="text" name="app_name" required value="<%= settings.app_name || 'Feuerwehr Übungsplaner' %>" 
                   class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Unterüberschrift (Subtitle)</label>
            <input type="text" name="app_subtitle" required value="<%= settings.app_subtitle || 'Freiwillige Feuerwehr' %>" 
                   class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
          </div>
        </div>

        <div class="border-t border-slate-200 dark:border-slate-800/60 pt-4">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-2">Templates für Push-Erinnerungen</h4>
          <p class="text-xs text-slate-500 dark:text-slate-400 mb-4 leading-relaxed">
            Passe die Betreffs- und Inhalts-Vorlage für deine automatischen Browser-Erinnerungen an. 
            Verwende <code class="text-brand-600 dark:text-brand-400 font-mono">{title}</code> für den Übungstitel und <code class="text-brand-600 dark:text-brand-400 font-mono">{date}</code> für das Übungsdatum.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Push-Titel (Betreff)</label>
              <input type="text" name="push_title_template" required value="<%= settings.push_title_template || 'Terminerinnerung: {title}' %>" 
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Push-Text (Inhalt)</label>
              <input type="text" name="push_body_template" required value="<%= settings.push_body_template || 'Nächste Übung am {date}. Bitte gib Rückmeldung.' %>" 
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
            </div>
          </div>
        </div>

        <div class="border-t border-slate-200 dark:border-slate-800/60 pt-4">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-2">Vorschläge für Schnellwahl-Kommentare</h4>
          <p class="text-xs text-slate-500 dark:text-slate-400 mb-3 leading-relaxed">
            Gib kommagetrennte Vorschläge ein, die dem Endnutzer als Schnellwahl-Buttons unter dem Kommentarfeld angezeigt werden.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Vorschläge bei Zusage (kommagetrennt)</label>
              <input type="text" name="suggestions_zusage" value="<%= settings.suggestions_zusage || '' %>" 
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors" placeholder="z. B. Bringe Kasten Spezi mit, Direkt vom Dienst">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Vorschläge bei Absage (kommagetrennt)</label>
              <input type="text" name="suggestions_absage" value="<%= settings.suggestions_absage || '' %>" 
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors" placeholder="z. B. Arbeit, Urlaub, Krankheit">
            </div>
          </div>
        </div>

        <div class="border-t border-slate-200 dark:border-slate-800/60 pt-4">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-2">Standard-Uhrzeiten pro Zielgruppe</h4>
          <p class="text-xs text-slate-500 dark:text-slate-400 mb-4 leading-relaxed">
            Beim Erstellen einer neuen Übung wird die Uhrzeit automatisch auf die hier hinterlegte Standard-Zeit gesetzt, sobald du eine Zielgruppe wählst.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-slate-400"></span>
                  Alle (Jugend &amp; Aktive)
                </span>
              </label>
              <input type="time" name="default_time_alle" value="<%= settings.default_time_alle || '19:00' %>"
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-blue-400"></span>
                  Jugendfeuerwehr
                </span>
              </label>
              <input type="time" name="default_time_jugend" value="<%= settings.default_time_jugend || '18:30' %>"
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-brand-500"></span>
                  Aktive Mannschaft
                </span>
              </label>
              <input type="time" name="default_time_aktive" value="<%= settings.default_time_aktive || '19:30' %>"
                     class="w-full px-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium text-sm transition-colors">
            </div>
          </div>
        </div>

        <div class="text-right border-t border-slate-200 dark:border-slate-800/60 pt-4">
          <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl text-sm transition-all shadow-lg shadow-brand-600/10">
            Einstellungen speichern
          </button>
        </div>
      </form>
    </div>

    <!-- Logo upload form -->
    <div class="glass-panel rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-3">Branding (Favicon & App-Logo)</h3>
      <p class="text-xs text-slate-500 dark:text-slate-400 mb-4 leading-relaxed">
        Lade hier ein quadratisches Bild hoch (PNG/JPG-Format, max. 2 MB). 
        Das Bild wird als Favicon, PWA-App-Icon und Logo in der Leiste verwendet. Es wird persistent in der SQLite-Datenbank gespeichert.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
        <!-- Current Logo preview -->
        <div class="flex flex-col items-center justify-center p-4 bg-slate-200/30 dark:bg-slate-900/40 rounded-xl border border-slate-200 dark:border-slate-800">
          <span class="text-[9px] font-bold text-slate-500 mb-2 uppercase tracking-wider">Aktuelles Logo</span>
          <div class="h-16 w-16 rounded-xl overflow-hidden bg-brand-600 flex items-center justify-center shadow">
            <img src="/logo-192.png" alt="Logo Preview" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Upload Form -->
        <form action="/admin/settings/upload-logo" method="POST" enctype="multipart/form-data" class="md:col-span-2 space-y-4">
          <div>
            <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Bilddatei auswählen</label>
            <input type="file" name="logo" accept="image/*" required 
                   class="w-full px-4 py-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-500 dark:text-slate-400 text-xs transition-colors">
          </div>
          <div class="flex gap-2">
            <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-lg text-xs transition-all shadow shadow-brand-600/10">
              Logo hochladen & anwenden
            </button>
          </div>
        </form>
      </div>

      <!-- Reset Logo option if a custom logo is active -->
      <% if (settings.custom_logo_base64) { %>
        <div class="border-t border-slate-200 dark:border-slate-800/60 pt-4 mt-6">
          <form action="/admin/settings/reset-logo" method="POST" onsubmit="return confirm('Möchtest du das Logo wirklich auf das Standard-Feuerwehr-Emblem zurücksetzen?');">
            <button type="submit" class="px-3 py-1.5 bg-red-50 border border-red-200 hover:bg-red-100 text-red-600 dark:bg-red-950/40 dark:border-red-900/60 dark:hover:bg-red-950/70 dark:text-red-400 text-xs font-semibold rounded-lg transition-colors">
              Logo löschen & Standard-Emblem wiederherstellen
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/air-datepicker@3.5.3/air-datepicker.js"></script>
<script>
  // Inline German locale for Air Datepicker (avoids CDN module issues)
  const deLocale = {
    days: ['Sonntag', 'Montag', 'Dienstag', 'Mittwoch', 'Donnerstag', 'Freitag', 'Samstag'],
    daysShort: ['Son', 'Mon', 'Die', 'Mit', 'Don', 'Fre', 'Sam'],
    daysMin: ['So', 'Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa'],
    months: ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'],
    monthsShort: ['Jan', 'Feb', 'Mär', 'Apr', 'Mai', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez'],
    today: 'Heute',
    clear: 'Löschen',
    dateFormat: 'dd.MM.yyyy',
    timeFormat: 'HH:mm',
    firstDay: 1
  };
  // Simple interactive tab switching logic (via hash routing from header links)
  const tabContentEvents = document.getElementById('tab-content-events');
  const tabContentPastEvents = document.getElementById('tab-content-past-events');
  const tabContentUsers = document.getElementById('tab-content-users');
  const tabContentAudit = document.getElementById('tab-content-audit');
  const tabContentSettings = document.getElementById('tab-content-settings');

  function switchTab(tab) {
    // Hide contents
    tabContentEvents.classList.add('hidden');
    if (tabContentPastEvents) tabContentPastEvents.classList.add('hidden');
    tabContentUsers.classList.add('hidden');
    tabContentAudit.classList.add('hidden');
    tabContentSettings.classList.add('hidden');

    // Activate selected
    if (tab === 'events') {
      tabContentEvents.classList.remove('hidden');
      window.location.hash = 'events';
    } else if (tab === 'past-events') {
      if (tabContentPastEvents) tabContentPastEvents.classList.remove('hidden');
      window.location.hash = 'past-events';
    } else if (tab === 'users') {
      tabContentUsers.classList.remove('hidden');
      window.location.hash = 'users';
    } else if (tab === 'audit') {
      tabContentAudit.classList.remove('hidden');
      window.location.hash = 'audit';
    } else if (tab === 'settings') {
      tabContentSettings.classList.remove('hidden');
      window.location.hash = 'settings';
    }
  }

  // Listen for hash changes to navigate directly to tabs (e.g. from registration redirect)
  function handleHashChange() {
    const hash = window.location.hash;
    if (hash === '#users') {
      switchTab('users');
    } else if (hash === '#past-events') {
      switchTab('past-events');
    } else if (hash === '#audit') {
      switchTab('audit');
    } else if (hash === '#settings') {
      switchTab('settings');
    } else {
      switchTab('events');
    }
  }

  window.addEventListener('hashchange', handleHashChange);
  // Initial check
  handleHashChange();

  // Toggle event creation form — also resets date picker state so default time applies fresh
  function toggleCreateEventForm() {
    const container = document.getElementById('create-event-container');
    container.classList.toggle('hidden');
    if (!container.classList.contains('hidden')) {
      container.scrollIntoView({ behavior: 'smooth' });
      // Reset date picker state so the group default time is applied on next date click
      dateHasBeenSelected = false;
      isApplyingDefault = false;
    }
  }

  // Default times per group (from global settings)
  const defaultTimes = {
    'ALLE':   '<%= settings.default_time_alle   || "19:00" %>',
    'JUGEND': '<%= settings.default_time_jugend || "18:30" %>',
    'AKTIVE': '<%= settings.default_time_aktive || "19:30" %>'
  };

  // Helper to write the ISO value into the hidden field
  function writeIsoValue(date) {
    if (!date) return;
    const pad = n => String(n).padStart(2, '0');
    const iso = `${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
    document.getElementById('event_date_hidden').value = iso;
  }

  // Flag to prevent infinite loop when we re-select with default time
  let isApplyingDefault = false;
  // Track if the user already picked a date this session (reset by toggleCreateEventForm)
  let dateHasBeenSelected = false;

  // Initialize Air Datepicker — stays open after date selection so user can pick time too
  const airDpInstance = new AirDatepicker('#event_date_picker', {
    locale: deLocale,
    timepicker: true,
    timeFormat: 'HH:mm',
    dateFormat: 'dd.MM.yyyy',
    isMobile: false,
    autoClose: false,
    toggleSelected: false,
    minutesStep: 5,
    buttons: [
      {
        content: 'Heute',
        className: 'air-datepicker-button',
        onClick: (dp) => { dp.selectDate(new Date()); }
      },
      'clear',
      {
        content: '&#10003; Übernehmen',
        className: 'air-datepicker-button',
        attrs: { style: 'background:var(--adp-accent-color);color:#fff;border-radius:8px;font-weight:700;padding:6px 14px;' },
        onClick: (dp) => { dp.hide(); }
      }
    ],
    classes: document.documentElement.classList.contains('dark') ? 'dark' : '',
    onSelect({ date }) {
      if (!date) {
        document.getElementById('event_date_hidden').value = '';
        dateHasBeenSelected = false;
        return;
      }

      // First date click: auto-apply the group's configured default time
      if (!isApplyingDefault && !dateHasBeenSelected) {
        dateHasBeenSelected = true;
        const group = document.querySelector('select[name="target_group"]').value;
        const timeStr = defaultTimes[group] || '19:00';
        const [dh, dm] = timeStr.split(':').map(Number);
        const newDate = new Date(date);
        newDate.setHours(dh, dm, 0, 0);
        isApplyingDefault = true;
        airDpInstance.selectDate(newDate);
        return;
      }

      isApplyingDefault = false;
      writeIsoValue(date);
    }
  });

  // When target group changes, update the time part of an already-selected date
  document.querySelector('select[name="target_group"]').addEventListener('change', function() {
    const selected = airDpInstance.selectedDates[0];
    if (!selected) return; // no date chosen yet → nothing to update
    const timeStr = defaultTimes[this.value] || '19:00';
    const [dh, dm] = timeStr.split(':').map(Number);
    const updated = new Date(selected);
    updated.setHours(dh, dm, 0, 0);
    isApplyingDefault = true; // skip the midnight-check in onSelect
    airDpInstance.selectDate(updated);
    writeIsoValue(updated);
  });

  // Keep Air Datepicker in sync with dark/light mode changes
  const themeBtn = document.getElementById('theme-toggle-btn');
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      requestAnimationFrame(() => {
        const isDark = document.documentElement.classList.contains('dark');
        const dp = airDpInstance.$datepicker;
        if (dp) {
          if (isDark) dp.classList.add('dark');
          else dp.classList.remove('dark');
        }
      });
    });
  }
</script>

<script>
  // WhatsApp Teilen: öffnet wa.me mit vorformatierter Nachricht
  function shareWhatsApp(eventId, title, date) {
    const url = `${window.location.origin}/event/${eventId}`;
    const text = encodeURIComponent(`🚒 *Übungseinladung: ${title}*\n📅 ${date} Uhr\n\nBitte gib deine Rückmeldung:\n${url}`);
    window.open(`https://wa.me/?text=${text}`, '_blank');
  }

  // Link kopieren mit kurzer visueller Bestätigung
  function copyEventLink(eventId) {
    const url = `${window.location.origin}/event/${eventId}`;
    navigator.clipboard.writeText(url).then(() => {
      const label = document.getElementById(`copy-label-${eventId}`);
      const icon  = document.getElementById(`copy-icon-${eventId}`);
      if (label) label.textContent = '✓ Kopiert!';
      if (icon) icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>';
      setTimeout(() => {
        if (label) label.textContent = 'Link kopieren';
        if (icon) icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
      }, 2000);
    }).catch(() => {
      // Fallback for older browsers
      const el = document.createElement('textarea');
      el.value = url;
      document.body.appendChild(el);
      el.select();
      document.execCommand('copy');
      document.body.removeChild(el);
    });
  }
</script>

<%- include('partials/footer') %>
