<!DOCTYPE html>
<html lang="de" class="h-full bg-slate-50 text-slate-900 transition-colors duration-200">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= appName %> - <%= appSubtitle %></title>
  
  <!-- PWA Meta Tags -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#dc2626">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="<%= appName %>">
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <script>
    // Tailored light/dark theme loader to prevent Flash of Unstyled Content (FOUC)
    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    tailwind.config = {
      darkMode: 'class', // Enable class-based dark mode
      theme: {
        extend: {
          fontFamily: {
            sans: ['Outfit', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#fef2f2',
              100: '#fee2e2',
              200: '#fecaca',
              300: '#fca5a5',
              400: '#f87171',
              500: '#ef4444',
              600: '#dc2626',
              700: '#b91c1c',
              800: '#991b1b',
              900: '#7f1d1d',
              950: '#450a0a',
            }
          }
        }
      }
    }
  </script>

  <style>
    /* Custom light mode defaults & dark overrides */
    .glass-panel {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(15, 23, 42, 0.08);
    }
    
    .dark .glass-panel {
      background: rgba(30, 41, 59, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    
    .glow-red {
      box-shadow: 0 4px 25px rgba(220, 38, 38, 0.06);
    }
    
    .dark .glow-red {
      box-shadow: 0 4px 25px rgba(220, 38, 38, 0.15);
    }

    .glow-active {
      box-shadow: 0 0 25px rgba(239, 68, 68, 0.2);
    }
    
    .dark .glow-active {
      box-shadow: 0 0 25px rgba(239, 68, 68, 0.3);
    }

    /* Form animations */
    .fade-enter {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .fade-enter-active {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body class="flex flex-col min-h-screen font-sans bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-200">

  <!-- Header -->
  <header class="sticky top-0 z-40 w-full glass-panel border-b border-slate-200 dark:border-slate-800/80">
    <div class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center space-x-3 hover:opacity-90 transition-opacity">
        <!-- Custom dynamic logo / icon -->
        <div class="h-10 w-10 rounded-xl overflow-hidden bg-gradient-to-tr from-brand-700 to-brand-500 flex items-center justify-center shadow-lg shadow-brand-500/20">
          <img src="/logo-192.png" alt="Logo" class="h-full w-full object-cover">
        </div>
        <div>
          <h1 class="text-base md:text-lg font-bold tracking-tight text-slate-900 dark:text-white leading-none"><%= appName %></h1>
          <span class="text-[9px] md:text-[10px] text-slate-500 dark:text-slate-400 font-semibold tracking-wider uppercase"><%= appSubtitle %></span>
        </div>
      </a>
      
      <div class="flex items-center space-x-2 md:space-x-2">
        <!-- Refresh Button -->
        <button onclick="window.location.reload()" title="Aktualisieren" 
                class="p-2 rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 bg-slate-200/50 hover:bg-slate-200/80 dark:bg-slate-800/40 dark:hover:bg-slate-800 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </button>

        <!-- Theme Toggle Button -->
        <button id="theme-toggle-btn" title="Design umschalten"
                class="p-2 rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 bg-slate-200/50 hover:bg-slate-200/80 dark:bg-slate-800/40 dark:hover:bg-slate-800 transition-colors">
          <!-- Sun icon (shows in dark mode) -->
          <svg id="theme-sun-icon" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon (shows in light mode) -->
          <svg id="theme-moon-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>

        <% if (locals.admin) { %>
          <!-- "+ Neue Übung" button: only shown on the admin page -->
          <% if (locals.isAdminPage) { %>
            <button onclick="toggleCreateEventForm()" 
                    class="flex items-center gap-1.5 px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white font-bold text-xs rounded-lg shadow shadow-brand-600/20 transition-all">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              <span class="hidden sm:inline">Neue Übung</span>
            </button>
          <% } %>

          <!-- Admin Burger Menu -->
          <div class="relative inline-block text-left" id="admin-menu-container">
            <button onclick="toggleAdminMenu(event)" class="p-2 rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 bg-slate-200/50 hover:bg-slate-200/80 dark:bg-slate-800/40 dark:hover:bg-slate-800 transition-all flex items-center gap-1">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
            
            <div id="admin-dropdown-menu" class="hidden absolute right-0 mt-2 w-52 rounded-xl glass-panel shadow-lg border border-slate-200 dark:border-slate-800 py-1.5 focus:outline-none z-50 transition-all duration-150 scale-95 opacity-0 origin-top-right">
              <div class="px-4 py-2 border-b border-slate-200/60 dark:border-slate-800/80 mb-1 flex flex-col">
                <span class="text-xs font-bold text-slate-800 dark:text-slate-200 leading-tight"><%= admin.name %></span>
                <span class="text-[10px] text-slate-400 dark:text-slate-500 truncate leading-none mt-0.5"><%= admin.email %></span>
              </div>
              <a href="/admin#events" onclick="closeAdminMenu()" class="flex items-center gap-2 px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-200/40 dark:hover:bg-slate-800/50 transition-colors">
                <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Übungsplanung
              </a>
              <a href="/admin#users" onclick="closeAdminMenu()" class="flex items-center gap-2 px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-200/40 dark:hover:bg-slate-800/50 transition-colors">
                <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Mitglieder
              </a>
              <a href="/admin#audit" onclick="closeAdminMenu()" class="flex items-center gap-2 px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-200/40 dark:hover:bg-slate-800/50 transition-colors">
                <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Audit-Log
              </a>
              <a href="/admin#settings" onclick="closeAdminMenu()" class="flex items-center gap-2 px-4 py-2 text-xs font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-200/40 dark:hover:bg-slate-800/50 transition-colors">
                <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Einstellungen
              </a>
              <div class="border-t border-slate-200/60 dark:border-slate-800/80 my-1"></div>
              <a href="/auth/logout" class="flex items-center gap-2 px-4 py-2 text-xs font-bold text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/20 transition-colors">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Abmelden
              </a>
            </div>
          </div>

          <script>
            function toggleAdminMenu(event) {
              event.stopPropagation();
              const dropdown = document.getElementById('admin-dropdown-menu');
              const isHidden = dropdown.classList.contains('hidden');
              
              if (isHidden) {
                dropdown.classList.remove('hidden');
                requestAnimationFrame(() => {
                  dropdown.classList.remove('scale-95', 'opacity-0');
                  dropdown.classList.add('scale-100', 'opacity-100');
                });
              } else {
                closeAdminMenu();
              }
            }

            function closeAdminMenu() {
              const dropdown = document.getElementById('admin-dropdown-menu');
              if (dropdown && !dropdown.classList.contains('hidden')) {
                dropdown.classList.add('scale-95', 'opacity-0');
                dropdown.classList.remove('scale-100', 'opacity-100');
                setTimeout(() => {
                  dropdown.classList.add('hidden');
                }, 150);
              }
            }

            document.addEventListener('click', (event) => {
              const container = document.getElementById('admin-menu-container');
              if (container && !container.contains(event.target)) {
                closeAdminMenu();
              }
            });
          </script>
        <% } %>
      </div>

    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-grow max-w-4xl w-full mx-auto px-4 py-8">
