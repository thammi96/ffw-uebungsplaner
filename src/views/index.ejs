<%- include('partials/header') %>

<div class="max-w-md mx-auto space-y-5">

  <!-- Welcome Banner -->
  <div class="glass-panel rounded-2xl p-6 glow-red">
    <h2 class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">Aktuelle Übungen</h2>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Klicke auf eine Übung, um deine Rückmeldung zu geben.</p>
  </div>

  <!-- Events list -->
  <% if (events.length === 0) { %>
    <div class="glass-panel rounded-2xl p-10 text-center space-y-3">
      <div class="h-14 w-14 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center mx-auto">
        <svg class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <p class="text-sm font-semibold text-slate-500 dark:text-slate-400">Keine Übungen geplant</p>
      <p class="text-xs text-slate-400 dark:text-slate-600">Aktuell sind keine bevorstehenden Übungen eingetragen.</p>
    </div>
  <% } else { %>
    <% events.forEach(event => { %>
      <a href="/event/<%= event.id %>" class="block glass-panel rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="h-1.5 bg-gradient-to-r from-brand-600 to-brand-400"></div>
        <div class="p-5">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300 border border-brand-200 dark:border-brand-800/40 mb-2">
                <%= event.target_group === 'ALLE' ? 'Jugend & Aktive' : (event.target_group === 'JUGEND' ? 'Jugendfeuerwehr' : 'Aktive Mannschaft') %>
              </span>
              <h3 class="text-base font-bold text-slate-900 dark:text-white leading-tight group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors"><%= event.title %></h3>
              <div class="flex items-center gap-1.5 mt-2 text-slate-600 dark:text-slate-400">
                <svg class="h-4 w-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="text-sm font-semibold"><%= event.formatted_date %> Uhr</span>
              </div>
              <% if (event.description) { %>
                <p class="text-xs text-slate-500 dark:text-slate-500 mt-2 leading-relaxed line-clamp-2"><%= event.description %></p>
              <% } %>
            </div>
            <!-- Attendance summary -->
            <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[11px] font-bold bg-green-100 dark:bg-green-950/50 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-900/40">
                <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                <%= event.yes_count %>
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[11px] font-bold bg-red-100 dark:bg-red-950/50 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-900/40">
                <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                <%= event.no_count %>
              </span>
            </div>
          </div>

          <div class="mt-4 pt-3 border-t border-slate-100 dark:border-slate-800/60 flex items-center justify-between">
            <span class="text-[11px] text-slate-400 dark:text-slate-600 font-medium">
              <%= event.days_until === 0 ? 'Heute!' : (event.days_until === 1 ? 'Morgen' : `in ${event.days_until} Tagen`) %>
            </span>
            <span class="text-xs font-bold text-brand-600 dark:text-brand-400 group-hover:underline flex items-center gap-1">
              Rückmeldung geben
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    <% }) %>
  <% } %>
</div>

<%- include('partials/footer') %>
