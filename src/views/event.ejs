<%- include('partials/header') %>

<div class="max-w-md mx-auto space-y-6">
  <!-- Event Card -->
  <div class="glass-panel rounded-2xl overflow-hidden shadow-sm dark:shadow-xl p-6 glow-red">
    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-brand-100 dark:bg-brand-900/50 text-brand-700 dark:text-brand-300 border border-brand-200 dark:border-brand-800/50 mb-3">
      Übung für: <%= event.target_group === 'ALLE' ? 'Jugend & Aktive' : (event.target_group === 'JUGEND' ? 'Jugendfeuerwehr' : 'Aktive Mannschaft') %>
    </span>
    
    <h2 class="text-xl md:text-2xl font-bold text-slate-900 dark:text-white tracking-tight leading-tight"><%= event.title %></h2>
    
    <div class="mt-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 pb-3">
      <div class="flex items-center space-x-2 text-slate-700 dark:text-slate-300">
        <svg class="h-5 w-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="font-semibold text-sm">
          <%= new Date(event.event_date).toLocaleString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %> Uhr
        </span>
      </div>
      
      <button onclick="downloadCalendarEvent()" class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 bg-slate-100 hover:bg-slate-200 dark:bg-slate-900 dark:hover:bg-slate-850 text-xs font-semibold text-brand-600 dark:text-brand-400 hover:text-brand-500 dark:hover:text-brand-300 rounded-lg border border-slate-200 dark:border-slate-800 transition-all shadow-sm self-start sm:self-auto">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 18h16" />
        </svg>
        Termin exportieren (.ics)
      </button>
    </div>

    <% if (event.description) { %>
      <div class="mt-4 text-slate-600 dark:text-slate-400 text-sm border-t border-slate-200 dark:border-slate-800/60 pt-4 leading-relaxed whitespace-pre-line">
        <%= event.description %>
      </div>
    <% } %>
  </div>

  <!-- Main Interactive Card -->
  <div class="glass-panel rounded-2xl p-6 shadow-sm dark:shadow-xl">
    <!-- Auto loading indicator -->
    <div id="loading-spinner" class="hidden py-8 text-center space-y-3">
      <div class="h-10 w-10 border-4 border-brand-200 border-t-brand-600 rounded-full animate-spin mx-auto"></div>
      <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">Daten werden abgeglichen...</p>
    </div>

    <!-- STEP 1: Phone Verification -->
    <div id="step-phone" class="space-y-4">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Rückmeldung abgeben</h3>
      <p class="text-xs text-slate-500 dark:text-slate-400">Trage deine Handynummer ein, um dich an- oder abzumelden.</p>
      
      <div class="space-y-3">
        <div>
          <label for="phone-input" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Handynummer</label>
          <input type="tel" id="phone-input" placeholder="z. B. 0176 12345678" 
                 class="w-full px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-600 font-medium transition-colors">
        </div>
        <button id="btn-check-phone" 
                class="w-full py-3 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl shadow-lg shadow-brand-600/15 transition-all duration-200">
          Weiter
        </button>
      </div>
      <p id="phone-error" class="text-xs text-brand-600 dark:text-brand-400 hidden mt-2"></p>
    </div>

    <!-- STEP 2A: Registration (If phone not found) -->
    <div id="step-register" class="space-y-4 hidden fade-enter">
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Neu registrieren</h3>
      <p class="text-xs text-slate-500 dark:text-slate-400">Deine Nummer ist noch nicht im System. Bitte registriere dich zuerst. Ein Admin wird dich dann freischalten.</p>
      
      <div class="space-y-3">
        <div>
          <label for="reg-name" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 font-semibold">Name, Vorname</label>
          <input type="text" id="reg-name" placeholder="z. B. Max Mustermann" 
                 class="w-full px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-600 font-medium transition-colors">
        </div>
        <div>
          <label for="reg-group" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5 font-semibold">Abteilung</label>
          <select id="reg-group" class="w-full px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 font-medium transition-colors">
            <option value="JUGEND">Jugendfeuerwehr</option>
            <option value="AKTIVE">Aktive Mannschaft</option>
            <option value="BEIDE">Beide / Ausbilder</option>
          </select>
        </div>
        <button id="btn-register" 
                class="w-full py-3 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl shadow-lg transition-all duration-200">
          Registrierung anfragen
        </button>
        <button id="btn-back-to-phone" class="w-full py-2 border border-slate-200 dark:border-slate-850 text-xs font-semibold text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 rounded-xl transition-colors">
          Zurück
        </button>
      </div>
      <p id="reg-error" class="text-xs text-brand-600 dark:text-brand-400 hidden mt-2"></p>
    </div>

    <!-- STEP 2B: Pending Approval -->
    <div id="step-pending" class="space-y-4 hidden text-center py-4 fade-enter">
      <div class="h-12 w-12 rounded-full bg-yellow-100 dark:bg-yellow-950/50 border border-yellow-300 dark:border-yellow-850 text-yellow-600 dark:text-yellow-500 flex items-center justify-center mx-auto mb-3">
        <svg class="h-6 w-6 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-bold text-slate-900 dark:text-white">Warten auf Freigabe</h3>
      <p class="text-sm text-slate-700 dark:text-slate-300">Dein Account (<span id="pending-name" class="font-bold text-brand-600 dark:text-brand-400"></span>) ist noch nicht freigeschaltet.</p>
      <p class="text-xs text-slate-500 dark:text-slate-400 max-w-xs mx-auto">Ein Administrator muss deine Rufnummer bestätigen. Sobald dies geschehen ist, kannst du dich hier anmelden.</p>
      <button onclick="window.location.reload()" class="mt-4 px-4 py-2 bg-slate-200 hover:bg-slate-300 dark:bg-slate-800 dark:hover:bg-slate-700 border border-slate-300 dark:border-slate-700 text-xs text-slate-700 dark:text-slate-300 rounded-xl transition-colors font-semibold shadow-sm">
        Aktualisieren
      </button>
    </div>

    <!-- STEP 2C: Signup Form (If approved) -->
    <div id="step-signup" class="space-y-4 hidden fade-enter">
      <div class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800/50 pb-3 mb-1">
        <div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white">Rückmeldung abgeben</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400">Hallo <span id="user-name" class="font-bold text-brand-600 dark:text-brand-500"></span></p>
        </div>
        <button id="btn-change-user" class="text-xs text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300 underline font-semibold">Abmelden</button>
      </div>

      <div class="space-y-4">
        <!-- Status selection buttons -->
        <div>
          <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-2">Rückmeldung</label>
          <div class="grid grid-cols-2 gap-3">
            <label class="relative flex items-center justify-center p-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/40 cursor-pointer select-none transition-all duration-200 shadow-sm" id="label-zusage">
              <input type="radio" name="signup-status" value="ZUSAGE" class="sr-only">
              <span class="text-sm font-bold text-slate-400 pointer-events-none transition-colors">Ich komme</span>
            </label>
            <label class="relative flex items-center justify-center p-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/40 cursor-pointer select-none transition-all duration-200 shadow-sm" id="label-absage">
              <input type="radio" name="signup-status" value="ABSAGE" class="sr-only">
              <span class="text-sm font-bold text-slate-400 pointer-events-none transition-colors">Ich fehle</span>
            </label>
          </div>
        </div>

        <!-- Freetext comments -->
        <div>
          <label for="signup-comment" class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5">Kommentar (optional)</label>
          <textarea id="signup-comment" rows="2" placeholder="z. B. bringe etwas mit oder Grund für Absage" 
                    class="w-full px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl focus:border-brand-500 focus:outline-none text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-650 font-medium transition-colors text-sm"></textarea>
          
          <!-- Auto-suggestions based on status choice -->
          <div id="suggestions-container" class="mt-2 hidden">
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Vorschläge:</span>
            <div id="suggestions-list" class="flex flex-wrap gap-1.5">
              <!-- Dynamically populated -->
            </div>
          </div>
        </div>

        <button id="btn-submit-signup" 
                class="w-full py-3 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl shadow-lg transition-all duration-200">
          Rückmeldung speichern
        </button>
      </div>
      <p id="signup-error" class="text-xs text-brand-600 dark:text-brand-400 hidden mt-2"></p>
    </div>

    <!-- STEP 3: Success & Push Activation -->
    <div id="step-success" class="space-y-5 hidden text-center py-4 fade-enter">
      <div class="h-14 w-14 rounded-full bg-green-100 dark:bg-green-950/60 border border-green-300 dark:border-green-500/30 text-green-600 dark:text-green-400 flex items-center justify-center mx-auto mb-3">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      
      <div>
        <h3 class="text-xl font-extrabold text-slate-900 dark:text-white">Vielen Dank!</h3>
        <p class="text-sm text-slate-700 dark:text-slate-300 mt-1">Deine Rückmeldung wurde erfolgreich gespeichert.</p>
      </div>

      <div class="border-t border-slate-200 dark:border-slate-800/60 pt-4 mt-2" id="push-activation-block">
        <h4 class="text-sm font-bold text-slate-900 dark:text-white">Nie wieder Übungen verpassen?</h4>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 max-w-xs mx-auto leading-relaxed">
          Aktiviere Push-Erinnerungen für diese App, um Benachrichtigungen direkt auf dein Smartphone zu erhalten.
        </p>
        <button id="btn-activate-push" 
                class="mt-4 w-full py-3 bg-gradient-to-tr from-brand-700 to-brand-500 text-white font-semibold rounded-xl shadow-lg shadow-brand-600/15 transition-all duration-200 transform hover:-translate-y-0.5 glow-active flex items-center justify-center gap-2">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          Erinnerungen auf diesem Gerät aktivieren
        </button>
      </div>

      <div class="hidden pt-4 border-t border-slate-200 dark:border-slate-800/60" id="push-success-block">
        <p class="text-xs font-bold text-green-600 dark:text-green-400 flex items-center justify-center gap-1.5">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Push-Erinnerungen sind auf diesem Gerät aktiv!
        </p>
      </div>
      
      <div class="pt-4 border-t border-slate-200 dark:border-slate-800/60">
        <button id="btn-back-to-signup" class="text-xs font-semibold text-brand-600 dark:text-brand-400 hover:text-brand-500 dark:hover:text-brand-300">
          Rückmeldung anpassen
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Save global VAPID key
  const publicVapidKey = '<%= publicVapidKey || "" %>';
  const eventId = '<%= event.id %>';
  
  let currentUser = null;
  let verifiedPhone = '';

  // Setup DOM Elements
  const stepPhone = document.getElementById('step-phone');
  const stepRegister = document.getElementById('step-register');
  const stepPending = document.getElementById('step-pending');
  const stepSignup = document.getElementById('step-signup');
  const stepSuccess = document.getElementById('step-success');
  const loadingSpinner = document.getElementById('loading-spinner');

  const phoneInput = document.getElementById('phone-input');
  const phoneError = document.getElementById('phone-error');
  const regName = document.getElementById('reg-name');
  const regGroup = document.getElementById('reg-group');
  const regError = document.getElementById('reg-error');
  const pendingName = document.getElementById('pending-name');
  const userName = document.getElementById('user-name');
  
  const labelZusage = document.getElementById('label-zusage');
  const labelAbsage = document.getElementById('label-absage');
  const signupComment = document.getElementById('signup-comment');
  const suggestionsContainer = document.getElementById('suggestions-container');
  const suggestionsList = document.getElementById('suggestions-list');
  const signupError = document.getElementById('signup-error');

  const pushActivationBlock = document.getElementById('push-activation-block');
  const pushSuccessBlock = document.getElementById('push-success-block');

  // Check subscription state locally
  if (localStorage.getItem('push_enabled_' + eventId)) {
    pushActivationBlock.classList.add('hidden');
    pushSuccessBlock.classList.remove('hidden');
  }

  // Animation helper
  function transitionTo(fromEl, toEl) {
    fromEl.classList.add('hidden');
    toEl.classList.remove('hidden');
    // Force reflow
    toEl.offsetHeight;
    toEl.classList.add('fade-enter-active');
  }

  // Reset errors
  function clearErrors() {
    phoneError.classList.add('hidden');
    regError.classList.add('hidden');
    signupError.classList.add('hidden');
  }

  // Handle Radio styling
  const radios = document.querySelectorAll('input[name="signup-status"]');
  radios.forEach(radio => {
    radio.addEventListener('change', (e) => {
      clearErrors();
      const selected = e.target.value;
      
      // Update UI selection classes
      if (selected === 'ZUSAGE') {
        labelZusage.className = 'relative flex items-center justify-center p-3 rounded-xl border border-brand-500 bg-brand-50 dark:bg-brand-950/20 text-brand-600 dark:text-brand-400 cursor-pointer select-none transition-all duration-200 shadow shadow-brand-500/10';
        labelZusage.querySelector('span').className = 'text-sm font-bold text-brand-600 dark:text-brand-400';
        
        labelAbsage.className = 'relative flex items-center justify-center p-3 rounded-xl border border-slate-250 dark:border-slate-800 bg-white dark:bg-slate-900/40 cursor-pointer select-none transition-all duration-200';
        labelAbsage.querySelector('span').className = 'text-sm font-bold text-slate-400 dark:text-slate-500';
        
        showSuggestions(['Bringe Kasten Bier mit', 'Bringe Cola mit', 'Fahre als Fahrer', 'Bringe Grillkohle mit', 'Direkt vom Dienst']);
      } else {
        labelAbsage.className = 'relative flex items-center justify-center p-3 rounded-xl border border-brand-500 bg-brand-50 dark:bg-brand-950/20 text-brand-600 dark:text-brand-400 cursor-pointer select-none transition-all duration-200 shadow shadow-brand-500/10';
        labelAbsage.querySelector('span').className = 'text-sm font-bold text-brand-600 dark:text-brand-400';
        
        labelZusage.className = 'relative flex items-center justify-center p-3 rounded-xl border border-slate-250 dark:border-slate-800 bg-white dark:bg-slate-900/40 cursor-pointer select-none transition-all duration-200';
        labelZusage.querySelector('span').className = 'text-sm font-bold text-slate-400 dark:text-slate-500';
        
        showSuggestions(['Privater Geburtstag', 'Spätschicht / Arbeit', 'Krankheit', 'Urlaub', 'Schule / Klausur']);
      }
    });
  });

  // Show auto-suggestions
  function showSuggestions(list) {
    suggestionsList.innerHTML = '';
    list.forEach(item => {
      const btn = document.createElement('button');
      btn.className = 'text-xs px-2.5 py-1.5 bg-slate-200/50 hover:bg-slate-200 dark:bg-slate-800 border border-slate-300 dark:border-slate-700/60 hover:text-slate-900 dark:hover:text-white rounded-lg transition-colors text-slate-600 dark:text-slate-300 font-semibold';
      btn.innerText = item;
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        signupComment.value = item;
      });
      suggestionsList.appendChild(btn);
    });
    suggestionsContainer.classList.remove('hidden');
  }

  // Check Phone number and transition screens
  async function performPhoneCheck(phone) {
    try {
      const response = await fetch(`/event/${eventId}/check-phone`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone_number: phone })
      });
      
      const data = await response.json();
      if (data.error) {
        phoneError.innerText = data.error;
        phoneError.classList.remove('hidden');
        loadingSpinner.classList.add('hidden');
        stepPhone.classList.remove('hidden');
        return;
      }

      verifiedPhone = phone;
      localStorage.setItem('ffw_user_phone', phone);

      loadingSpinner.classList.add('hidden');

      if (data.status === 'not_found') {
        transitionTo(stepPhone, stepRegister);
      } else if (data.status === 'pending') {
        pendingName.innerText = data.name;
        stepPhone.classList.add('hidden');
        stepPending.classList.remove('hidden');
        stepPending.classList.add('fade-enter-active');
      } else if (data.status === 'approved') {
        currentUser = data.user;
        userName.innerText = data.user.name;
        
        // Pre-fill existing signup if present
        if (data.signup) {
          const status = data.signup.status;
          const radioBtn = document.querySelector(`input[name="signup-status"][value="${status}"]`);
          if (radioBtn) {
            radioBtn.checked = true;
            // trigger change event to style UI
            radioBtn.dispatchEvent(new Event('change'));
          }
          signupComment.value = data.signup.comment || '';
        }
        
        stepPhone.classList.add('hidden');
        stepSignup.classList.remove('hidden');
        stepSignup.classList.add('fade-enter-active');
      }
    } catch (err) {
      console.error(err);
      phoneError.innerText = 'Verbindungsfehler beim Abgleichen.';
      phoneError.classList.remove('hidden');
      loadingSpinner.classList.add('hidden');
      stepPhone.classList.remove('hidden');
    }
  }

  // STEP 1 Action: Check Phone Manual Trigger
  document.getElementById('btn-check-phone').addEventListener('click', () => {
    clearErrors();
    const phone = phoneInput.value.trim();
    if (!phone) {
      phoneError.innerText = 'Bitte gib deine Handynummer an.';
      phoneError.classList.remove('hidden');
      return;
    }
    performPhoneCheck(phone);
  });

  // STEP 2A Action: Register
  document.getElementById('btn-register').addEventListener('click', async () => {
    clearErrors();
    const name = regName.value.trim();
    const groupType = regGroup.value;
    
    if (!name) {
      regError.innerText = 'Bitte gib deinen Namen an.';
      regError.classList.remove('hidden');
      return;
    }

    try {
      const response = await fetch(`/event/${eventId}/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone_number: verifiedPhone, group_type: groupType })
      });
      
      const data = await response.json();
      if (data.error) {
        regError.innerText = data.error;
        regError.classList.remove('hidden');
        return;
      }
      
      pendingName.innerText = name;
      transitionTo(stepRegister, stepPending);
    } catch (err) {
      console.error(err);
      regError.innerText = 'Verbindungsfehler bei der Registrierung.';
      regError.classList.remove('hidden');
    }
  });

  // Back Button
  document.getElementById('btn-back-to-phone').addEventListener('click', () => {
    transitionTo(stepRegister, stepPhone);
  });

  // Change User
  document.getElementById('btn-change-user').addEventListener('click', () => {
    currentUser = null;
    verifiedPhone = '';
    localStorage.removeItem('ffw_user_phone');
    phoneInput.value = '';
    transitionTo(stepSignup, stepPhone);
  });

  // STEP 2C Action: Submit Signup
  document.getElementById('btn-submit-signup').addEventListener('click', async () => {
    clearErrors();
    const checkedRadio = document.querySelector('input[name="signup-status"]:checked');
    if (!checkedRadio) {
      signupError.innerText = 'Bitte wähle Zusage oder Absage.';
      signupError.classList.remove('hidden');
      return;
    }

    const status = checkedRadio.value;
    const comment = signupComment.value.trim();

    try {
      const response = await fetch(`/event/${eventId}/signup`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone_number: verifiedPhone, status, comment })
      });

      const data = await response.json();
      if (data.error) {
        signupError.innerText = data.error;
        signupError.classList.remove('hidden');
        return;
      }

      currentUser.id = data.userId; // Ensure we have the user ID for push subscription
      transitionTo(stepSignup, stepSuccess);
    } catch (err) {
      console.error(err);
      signupError.innerText = 'Verbindungsfehler beim Speichern der Rückmeldung.';
      signupError.classList.remove('hidden');
    }
  });

  // Back to Signup (adjust attendance)
  document.getElementById('btn-back-to-signup').addEventListener('click', () => {
    transitionTo(stepSuccess, stepSignup);
  });

  // STEP 3 Action: Web Push Activation
  document.getElementById('btn-activate-push').addEventListener('click', async () => {
    if (!publicVapidKey) {
      alert('Push-Dienst ist serverseitig nicht konfiguriert (VAPID-Schlüssel fehlen).');
      return;
    }

    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      alert('Push-Benachrichtigungen werden von diesem Browser nicht unterstützt.');
      return;
    }

    try {
      const permission = await Notification.requestPermission();
      if (permission !== 'granted') {
        alert('Push-Berechtigung wurde verweigert.');
        return;
      }

      const reg = await navigator.serviceWorker.ready;
      const subscription = await reg.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(publicVapidKey)
      });

      const response = await fetch('/push/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId: currentUser.id,
          subscription: subscription
        })
      });

      const data = await response.json();
      if (data.status === 'success') {
        localStorage.setItem('push_enabled_' + eventId, 'true');
        pushActivationBlock.classList.add('hidden');
        pushSuccessBlock.classList.remove('hidden');
      } else {
        alert('Fehler beim Aktivieren der Push-Benachrichtigungen auf dem Server.');
      }
    } catch (err) {
      console.error('Error setting up Push Subscription:', err);
      alert('Fehler bei der Aktivierung der Push-Erinnerungen: ' + err.message);
    }
  });

  // VAPID base64 helper
  function urlBase64ToUint8Array(base64String) {
    const padding = '='.repeat((4 - base64String.length % 4) % 4);
    const base64 = (base64String + padding)
      .replace(/\-/g, '+')
      .replace(/_/g, '/');

    const rawData = window.atob(base64);
    const outputArray = new Uint8Array(rawData.length);

    for (let i = 0; i < rawData.length; ++i) {
      outputArray[i] = rawData.charCodeAt(i);
    }
    return outputArray;
  }

  // Export event to calendar (.ics format)
  function downloadCalendarEvent() {
    const title = <%- JSON.stringify(event.title) %>;
    const description = <%- JSON.stringify(event.description || '') %>;
    const dateStr = "<%= event.event_date %>";
    
    const date = new Date(dateStr);
    
    // Format to UTC YYYYMMDDTHHMMSSZ
    function formatICSDate(d) {
      return d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    }
    
    // Event duration 2 hours
    const endDate = new Date(date.getTime() + 2 * 60 * 60 * 1000);
    
    const startFormatted = formatICSDate(date);
    const endFormatted = formatICSDate(endDate);
    
    const icsLines = [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//FFW Uebungsplaner//Calendar Event//DE',
      'CALSCALE:GREGORIAN',
      'METHOD:PUBLISH',
      'BEGIN:VEVENT',
      `UID:${Date.now()}@ffw-uebungsplaner.local`,
      `DTSTAMP:${formatICSDate(new Date())}`,
      `DTSTART:${startFormatted}`,
      `DTEND:${endFormatted}`,
      `SUMMARY:${title.replace(/[,;]/g, '\\$&')}`,
      `DESCRIPTION:${description.replace(/[\r\n]+/g, '\\n').replace(/[,;]/g, '\\$&')}`,
      'LOCATION:Feuerwehrgerätehaus',
      'STATUS:CONFIRMED',
      'SEQUENCE:0',
      'END:VEVENT',
      'END:VCALENDAR'
    ];
    
    const icsContent = icsLines.join('\r\n');
    const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', `${title.replace(/[^a-z0-9]/gi, '_').toLowerCase()}.ics`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  // Automatic Check on load if phone number is saved in local storage!
  // This resolves the user experience bug when reloading pages.
  window.addEventListener('load', () => {
    const savedPhone = localStorage.getItem('ffw_user_phone');
    if (savedPhone) {
      phoneInput.value = savedPhone;
      // Hide input screen, show loader
      stepPhone.classList.add('hidden');
      loadingSpinner.classList.remove('hidden');
      performPhoneCheck(savedPhone);
    }
  });
</script>

